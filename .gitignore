*.private
*.secret
*.key
id_rsa
id_dsa
*.ppk

# Credentials
credentials.json
secrets.json
*.credentials
*.secrets

# =====================================================
# Logs and Temporary Files
# =====================================================
logs/
*.log
*.log.*
log/
*.out
*.pid
*.seed
*.pid.lock

# Application logs
application.log
error.log
access.log

# =====================================================
# Build and Deployment
# =====================================================
# Build outputs
out/
build/
dist/
target/
bin/
obj/

# Deployment
deploy/
.deploy/
*.war
*.ear

# =====================================================
# Testing
# =====================================================
# Test coverage
coverage/
.nyc_output/
*.coverage
*.coverage.*
.coverage.*

# Test results
test-results/
test-output/
surefire-reports/
failsafe-reports/

# =====================================================
# Configuration (Sensitive)
# =====================================================
# Local configuration files
application-local.properties
application-local.yml
application-dev.properties
application-dev.yml
config.local.*

# =====================================================
# Miscellaneous
# =====================================================
# Backup files
*.bak
*.backup
*.old
*.orig
*.save
*.swp
*.tmp

# Archives
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# OS generated files
.DS_Store?
ehthumbs.db
Icon?
Thumbs.db

# Temporary folders
tmp/
temp/
.tmp/
.temp/

# =====================================================
# Project Specific
# =====================================================
# Deployment folder (if contains sensitive data)
OT_deployment/

# Local database dumps
*.sql.dump
*.sql.backup

# Local scripts (if they contain sensitive info)
setup-local.*
config-local.*

# =====================================================
# Keep Important Files
# =====================================================
# Keep README.md
!README.md

# Keep setup scripts (they're safe)
!database-setup.sql
!database-setup.bat
!database-setup.sh

# Keep docker-compose files (but not override)
!docker-compose.yml
!docker-compose.override.yml.example

# Keep example files
!*.example
!*.sample
!*.template

